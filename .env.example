# Backend (copy to backend/.env or export before `npm run dev`)
PORT=4000
NODE_ENV=development
DATABASE_URL=file:./prisma/data/dev.db
FRONTEND_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=sid
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_MS=604800000
# Optional: where uploaded client documents are stored (default: backend/uploads)
# UPLOAD_DIR=/absolute/path/to/uploads
# Optional: where deleted files are moved (default: backend/trash)
# TRASH_DIR=/absolute/path/to/trash
# MAX_UPLOAD_BYTES=10485760
SEED_EMAIL=admin@example.com
SEED_PASSWORD=changeme

# Docker Compose (optional)
# SESSION_SECRET=...
# SEED_EMAIL=...
# SEED_PASSWORD=...
